{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Run app.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "env": {
        "FLASK_ENV": "development"
      },
      "justMyCode": true
    },
    {
      "name": "Python: Flask (module)",
      "type": "python",
      "request": "launch",
      "module": "flask",
      "args": ["run", "--no-debugger"],
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_ENV": "development"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Attach to Process",
      "type": "python",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      }
    }
  ]
}
